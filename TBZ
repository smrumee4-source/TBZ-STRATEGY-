<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TBZ Binary Bot | Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body { background-color: #0f172a; color: white; }
        .glass { background: rgba(255, 255, 255, 0.05); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.1); }
    </style>
</head>
<body class="p-4 md:p-8">

    <div class="flex justify-between items-center mb-8 glass p-6 rounded-2xl">
        <div>
            <h1 class="text-2xl font-bold text-blue-400"><i class="fas fa-robot mr-2"></i> TBZ SMART BOT</h1>
            <p class="text-gray-400 text-sm">Status: <span class="text-green-400">● Live Market</span></p>
        </div>
        <div class="text-right">
            <p class="text-xs text-gray-400 uppercase">Balance</p>
            <h2 class="text-xl font-mono">$1,245.50</h2>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        
        <div class="lg:col-span-1 space-y-6">
            <div class="glass p-6 rounded-2xl">
                <h3 class="text-lg font-semibold mb-4 border-b border-gray-700 pb-2">Bot Settings</h3>
                
                <div class="mb-4">
                    <label class="block text-sm text-gray-400 mb-2 font-medium">Strategy Combo</label>
                    <select class="w-full bg-slate-800 border border-gray-600 rounded-lg p-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
                        <option>SMC + RSI + Engulfing</option>
                        <option>Price Action + Bollinger</option>
                        <option>Order Block Only</option>
                    </select>
                </div>

                <div class="grid grid-cols-2 gap-4 mb-6">
                    <div>
                        <label class="block text-sm text-gray-400 mb-1">Trade Amount</label>
                        <input type="number" value="10" class="w-full bg-slate-800 border border-gray-600 rounded-lg p-2 outline-none">
                    </div>
                    <div>
                        <label class="block text-sm text-gray-400 mb-1">Expiry (Min)</label>
                        <input type="number" value="1" class="w-full bg-slate-800 border border-gray-600 rounded-lg p-2 outline-none">
                    </div>
                </div>

                <div class="flex flex-col gap-3">
                    <button class="bg-green-600 hover:bg-green-700 text-white font-bold py-3 rounded-xl transition-all shadow-lg active:scale-95">
                        <i class="fas fa-play mr-2"></i> START BOT
                    </button>
                    <button class="bg-red-600 hover:bg-red-700 text-white font-bold py-3 rounded-xl transition-all shadow-lg active:scale-95">
                        <i class="fas fa-stop mr-2"></i> STOP BOT
                    </button>
                </div>
            </div>

            <div class="glass p-6 rounded-2xl border-l-4 border-yellow-500">
                <h3 class="text-md font-semibold mb-2 italic text-yellow-500">Risk Manager</h3>
                <div class="flex justify-between text-sm">
                    <span>Stop Loss:</span>
                    <span class="text-red-400">$50.00</span>
                </div>
                <div class="flex justify-between text-sm mt-1">
                    <span>Daily Target:</span>
                    <span class="text-green-400">$100.00</span>
                </div>
            </div>
        </div>

        <div class="lg:col-span-2 glass rounded-2xl overflow-hidden relative min-h-[400px]">
             <div class="absolute inset-0 flex items-center justify-center bg-slate-900/50">
                <p class="text-gray-500"><i class="fas fa-chart-line mr-2"></i> Live Chart Integration (TradingView)</p>
            </div>
            <div class="absolute bottom-4 left-4 right-4 flex justify-between">
                <div class="bg-black/60 p-3 rounded-lg border border-green-500/50">
                    <p class="text-xs text-gray-400 uppercase">Last Signal</p>
                    <p class="text-green-400 font-bold font-mono">CALL @ 1.0942</p>
                </div>
                <div class="bg-black/60 p-3 rounded-lg border border-blue-500/50">
                    <p class="text-xs text-gray-400 uppercase">Win Rate</p>
                    <p class="text-blue-400 font-bold font-mono text-xl">84%</p>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-8 glass rounded-2xl p-6">
        <h3 class="text-lg font-semibold mb-4">Live Trade History</h3>
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead>
                    <tr class="text-gray-500 text-sm border-b border-gray-700">
                        <th class="pb-3">Asset</th>
                        <th class="pb-3">Direction</th>
                        <th class="pb-3">Amount</th>
                        <th class="pb-3">Result</th>
                        <th class="pb-3">Time</th>
                    </tr>
                </thead>
                <tbody class="text-sm">
                    <tr class="border-b border-gray-800">
                        <td class="py-4">EUR/USD (OTC)</td>
                        <td class="text-green-400 font-bold">UP</td>
                        <td>$10.00</td>
                        <td class="text-green-400">+$18.70</td>
                        <td class="text-gray-500">14:20:05</td>
                    </tr>
                    <tr class="border-b border-gray-800">
                        <td class="py-4">AUD/CAD</td>
                        <td class="text-red-400 font-bold">DOWN</td>
                        <td>$10.00</td>
                        <td class="text-red-400">-$10.00</td>
                        <td class="text-gray-500">14:15:32</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

</body>
</html>
